# Realm server reverse proxy — auto-TLS + transparent WebSocket upgrade.
#
# Why this exists: the Vercel frontend is served over HTTPS, so the browser
# refuses to open an insecure ws:// socket (mixed content). Caddy gives the
# realm server a real Let's Encrypt cert on a hostname, turning it into wss://
# with no domain purchase (realm.gotchicloset.com is a subdomain you own).
#
# Prereqs:
#   - realm.gotchicloset.com  A  ->  THIS VPS's public IP
#   - firewall opens 80 + 443 (80 is required for the ACME challenge)
#   - the realm server is running on localhost:8080 (PM2, see ecosystem.config.cjs)
#
# Run:  sudo caddy start --config /srv/gv2/deploy/Caddyfile
# Caddy v2 fetches/renews the cert automatically and passes ws:// upgrades
# straight through — no extra directives needed.

realm.gotchicloset.com {
	reverse_proxy localhost:8080
}
